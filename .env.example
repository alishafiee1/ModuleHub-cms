# ModuleHub CMS — Ubuntu Server defaults
PORT=4000
NODE_ENV=production

ADMIN_PASSWORD=change-me
ADMIN_ROLE=admin
SESSION_SECRET=change-me-session-secret

MODULES_JSON_PATH=/var/lib/modulehub/modules.json
SITE_LAYOUT_JSON_PATH=/var/lib/modulehub/site-layout.json
BUILTIN_MODULES_DIR=./core/builtin-modules
CATALOG_MODULES_DIR=./core/catalog-modules
STANDALONE_MODULES_DIR=./standalone-modules
# STATIC_MODULES_DIR=./static-modules  # ⛔ DEPRECATED — use CATALOG_MODULES_DIR (read-only templates)
DOCKER_SOCKET=unix:///var/run/docker.sock
