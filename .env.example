# ModuleHub CMS — copy to .env on server only (/opt/modulehub-cms/.env)
# Never commit .env (see .gitignore)

NODE_ENV=production
SESSION_SECRET=change-me-long-random-string
ADMIN_PASSWORD_HASH=

# Local dev only (phase 8 replaces with real login) — enables + card and /admin/* until auth ships
# MODULEHUB_DEV_SUPER_ADMIN=1

# dual-WAN: NIC for git pull / npm (temporary route only)
# MODULEHUB_PACKAGE_INSTALL_INTERFACE=enp63s0
# MODULEHUB_SKIP_WAN=1

# package cache: npm path when systemd PATH has no nvm (auto-detected from ~/.nvm if unset)
# MODULEHUB_NPM_PATH=/home/ash/.nvm/versions/node/v20.20.2/bin/npm
