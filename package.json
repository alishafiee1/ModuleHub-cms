{
  "name": "modulehub-cms",
  "version": "0.1.0",
  "description": "Modular CMS with static and Docker standalone modules for Ubuntu Server",
  "main": "dist/core/src/server/index.js",
  "scripts": {
    "dev": "tsx watch core/src/server/index.ts",
    "build": "tsc && node scripts/copy-assets.js",
    "start": "node dist/core/src/server/index.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint core/src tests --ext .ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
